# ============================================================
# .env.example — このファイルを .env にコピーして値を入力する
# .env は絶対に git に含めないこと（.gitignore に追加すること）
# ============================================================

# bitbank API（https://bitbank.cc/api/setting から取得）
BITBANK_API_KEY=ここにAPIキーを貼る
BITBANK_API_SECRET=ここにAPIシークレットを貼る

# Discord Webhook URL（Discordのサーバー設定 → 連携サービス → Webhooksから作成）
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxxxxxxx/xxxxxxxxxxxx

# OANDA東京サーバー（Phase 2まで空欄でOK）
OANDA_TOKYO_ACCOUNT_ID=
OANDA_TOKYO_API_TOKEN=
